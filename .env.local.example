# Firebase Client Config (safe to be public)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Community Links (can be updated without code changes)
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/placeholder
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/groups/placeholder
NEXT_PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/placeholder

# Firebase Admin SDK (NEVER prefix with NEXT_PUBLIC_)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Resend (email sending)
RESEND_API_KEY=re_your_resend_api_key

# Admin access — comma-separated list of emails allowed into /admin
ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com

# Set to "true" to use local Firebase emulators for development
NEXT_PUBLIC_USE_EMULATOR=false
